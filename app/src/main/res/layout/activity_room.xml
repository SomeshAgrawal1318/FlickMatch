<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141416"
    android:orientation="vertical">

    <!-- TAB BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1E1E21"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tabLobby"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:text="Lobby"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabSwipe"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:text="Swipe"
            android:textColor="#717171"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tabWatchlist"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:text="Watchlist"
            android:textColor="#717171"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- CONTENT -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- SECTION 0: LOBBY -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/textRoomTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F5F5F5"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Invite code card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ROOM CODE"
                        android:textColor="#717171"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textInviteCode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_invite_code"
                            android:gravity="center"
                            android:padding="12dp"
                            android:textColor="#E07848"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:typeface="monospace" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/buttonCopyCode"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_button_primary"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Copy"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Share this code with friends to join"
                        android:textColor="#717171"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Members card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBERS"
                        android:textColor="#717171"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <LinearLayout
                        android:id="@+id/layoutMembers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/buttonStartSwiping"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Start Swiping"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>

        <!-- SECTION 1: SWIPE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <!-- Movie card -->
            <FrameLayout
                android:id="@+id/movieCard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_movie_card"
                android:clipToOutline="true"
                android:elevation="8dp">

                <ImageView
                    android:id="@+id/imagePoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Movie poster"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_card_overlay" />

                <!-- Text at the bottom of the card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/textMovieTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F5F5F5"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:shadowColor="#AA000000"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="4" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textMovieYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#E8E8E8"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="4dp"
                            android:layout_height="4dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:background="#717171"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:id="@+id/textMovieRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#F5C518"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textMovieOverview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:textColor="#E8E8E8"
                        android:textSize="11sp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </FrameLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/textEmptySwipe"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="No more movies!\nAdjust filters or check back later."
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Nope / Like -->
            <LinearLayout
                android:id="@+id/layoutSwipeButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/buttonNope"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_nope"
                    android:text="✕  Nope"
                    android:textColor="#E07848"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/buttonLike"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_like"
                    android:text="♡  Like"
                    android:textColor="#E8E8E8"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION 2: WATCHLIST -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <!-- Sort chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Sort"
                    android:textColor="#717171"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/sortMatchOrder"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_sort_active"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Match Order"
                    android:textColor="#E8E8E8"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/sortRating"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_sort_inactive"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Rating"
                    android:textColor="#717171"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/sortPopularity"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_sort_inactive"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Popular"
                    android:textColor="#717171"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/textEmptyWatchlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:gravity="center"
                android:text="No matches yet.\nKeep swiping!"
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/headerMatched"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:text="MATCHES"
                android:textColor="#717171"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerWatchlist"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/headerWatched"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:text="WATCHED"
                android:textColor="#717171"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerWatched"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </ViewFlipper>
</LinearLayout>