<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141416">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ROOM NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Room name"
            android:textColor="#E07848"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.06" />

        <EditText
            android:id="@+id/editRoomName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="e.g., Friday Movie Night"
            android:textColorHint="#555555"
            android:inputType="textCapSentences"
            android:maxLength="50"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#F0F0F0"
            android:textSize="13sp" />

        <!-- GENRES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="#E07848"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Genres"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick at least one"
                android:textColor="#717171"
                android:textSize="11sp" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/gridGenres"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="3"
            android:rowCount="6" />

        <!-- MAX RUNTIME -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="#E07848"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Max runtime"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textRuntime"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="240 min"
                android:textColor="#E07848"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekRuntime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:max="180"
            android:progress="180"
            android:progressTint="#E07848"
            android:thumbTint="#E07848" />

        <!-- AGE RATINGS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="#E07848"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age ratings"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbRatingG"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:buttonTint="#E07848"
                android:checked="true"
                android:text="G"
                android:textColor="#E8E8E8"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/cbRatingPG"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:buttonTint="#E07848"
                android:checked="true"
                android:text="PG"
                android:textColor="#E8E8E8"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/cbRatingPG13"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:buttonTint="#E07848"
                android:checked="true"
                android:text="PG-13"
                android:textColor="#E8E8E8"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/cbRatingR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#E07848"
                android:checked="true"
                android:text="R"
                android:textColor="#E8E8E8"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- YEAR RANGE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="#E07848"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Release year"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textYearRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2000 — 2026"
                android:textColor="#E07848"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="FROM"
            android:textColor="#717171"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <SeekBar
            android:id="@+id/seekYearMin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:max="56"
            android:progress="30"
            android:progressTint="#E07848"
            android:thumbTint="#E07848" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="TO"
            android:textColor="#717171"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <SeekBar
            android:id="@+id/seekYearMax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:max="56"
            android:progress="56"
            android:progressTint="#E07848"
            android:thumbTint="#E07848" />

        <!-- CREATE BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonCreateRoom"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_primary"
            android:text="Create Room"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>