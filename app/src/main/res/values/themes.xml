<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.FlickMatch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">#141416</item>
    </style>

    <style name="Theme.FlickMatch" parent="Base.Theme.FlickMatch" />

    <!-- Dialog Title Style -->
    <style name="DialogTitleStyle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">#E8E8E8</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!-- Dialog Message Style -->
    <style name="DialogMessageStyle" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">#E8E8E8</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Custom AlertDialog Theme -->
    <style name="CustomAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">

        <!-- Dark dialog background -->
        <item name="android:background">#1E1E21</item>
        <item name="android:backgroundTint">#1E1E21</item>

        <!-- Button accent color -->
        <item name="colorPrimary">#E07848</item>

        <!-- Title & Message -->
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DialogMessageStyle</item>

        <!-- FIX FOR EDITTEXT TEXT COLOR -->
        <item name="android:textColorPrimary">#E8E8E8</item>
        <item name="android:editTextColor">#E8E8E8</item>
        <item name="colorControlNormal">#E07848</item>           <!-- cursor & underline -->
        <item name="colorOnSurface">#E8E8E8</item>
        <item name="colorOnSurfaceVariant">#E07848</item>

        <!-- Hint color (slightly dimmer) -->
        <item name="android:textColorHint">#888888</item>
    </style>

</resources>